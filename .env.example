# Copy this file to .env and fill in your values
# NEVER commit the real .env file

# Groq API key — get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Qdrant vector database URL (default: local Docker container)
QDRANT_URL=http://localhost:6333

# Qdrant API key — get yours at https://cloud.qdrant.io/
QDRANT_API_KEY=your_qdrant_api_key_here

# Redis URL for semantic cache (default: local Docker container)
REDIS_URL=redis://localhost:6379

# Target API URL for cloud evaluation and Streamlit UI (default: local Docker container)
#API_URL=http://localhost:8000
API_URL=https://enterprise-ai-analyst-883304283246.europe-west1.run.app

